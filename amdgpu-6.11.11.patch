diff -Nuarp drm-6.11.11.orig/amd/amdgpu/amdgpu_job.c drm-6.11.11/amd/amdgpu/amdgpu_job.c
--- drm-6.11.11.orig/amd/amdgpu/amdgpu_job.c	2024-12-05 21:54:34.000000000 +0900
+++ drm-6.11.11/amd/amdgpu/amdgpu_job.c	2026-06-15 12:20:54.316046624 +0900
@@ -51,11 +51,20 @@ static enum drm_gpu_sched_stat amdgpu_jo
 
 	adev->job_hang = true;
 
-	if (amdgpu_gpu_recovery &&
-	    amdgpu_ring_soft_recovery(ring, job->vmid, s_job->s_fence->parent)) {
-		dev_err(adev->dev, "ring %s timeout, but soft recovered\n",
-			s_job->sched->name);
-		goto exit;
+	if (amdgpu_gpu_recovery) {
+		int retry;
+
+		for (retry = 0; retry < 3; retry++) {
+			if (amdgpu_ring_soft_recovery(ring, job->vmid,
+						      s_job->s_fence->parent)) {
+				dev_err(adev->dev,
+					"ring %s timeout, soft recovered (attempt %d)\n",
+					s_job->sched->name, retry + 1);
+				goto exit;
+			}
+			if (retry < 2)
+				msleep(100);
+		}
 	}
 
 	dev_err(adev->dev, "ring %s timeout, signaled seq=%u, emitted seq=%u\n",
diff -Nuarp drm-6.11.11.orig/amd/amdgpu/gfx_v7_0.c drm-6.11.11/amd/amdgpu/gfx_v7_0.c
--- drm-6.11.11.orig/amd/amdgpu/gfx_v7_0.c	2024-12-05 21:54:34.000000000 +0900
+++ drm-6.11.11/amd/amdgpu/gfx_v7_0.c	2026-06-15 12:20:21.693494408 +0900
@@ -4035,12 +4035,28 @@ static void gfx_v7_0_ring_soft_recovery(
 {
 	struct amdgpu_device *adev = ring->adev;
 	uint32_t value = 0;
+	u32 status;
 
+	/* Kill stuck wavefronts in this VMID */
 	value = REG_SET_FIELD(value, SQ_CMD, CMD, 0x03);
 	value = REG_SET_FIELD(value, SQ_CMD, MODE, 0x01);
 	value = REG_SET_FIELD(value, SQ_CMD, CHECK_VMID, 1);
 	value = REG_SET_FIELD(value, SQ_CMD, VM_ID, vmid);
 	WREG32(mmSQ_CMD, value);
+
+	/* If the CP itself is hung, briefly halt and restart ME/PFP/CE.
+	 * SQ_CMD only kills shader wavefronts; a hung CP needs an explicit
+	 * restart so the ring can make forward progress and signal the fence.
+	 */
+	status = RREG32(mmGRBM_STATUS);
+	if (status & (GRBM_STATUS__CP_BUSY_MASK | GRBM_STATUS__CP_COHERENCY_BUSY_MASK)) {
+		WREG32(mmCP_ME_CNTL,
+		       CP_ME_CNTL__ME_HALT_MASK |
+		       CP_ME_CNTL__PFP_HALT_MASK |
+		       CP_ME_CNTL__CE_HALT_MASK);
+		udelay(10);
+		WREG32(mmCP_ME_CNTL, 0);
+	}
 }
 
