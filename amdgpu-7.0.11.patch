diff -Nuarp drm-7.0.11.orig/amd/amdgpu/amdgpu_device.c drm-7.0.11/amd/amdgpu/amdgpu_device.c
--- drm-7.0.11.orig/amd/amdgpu/amdgpu_device.c	2026-06-02 00:54:55.000000000 +0900
+++ drm-7.0.11/amd/amdgpu/amdgpu_device.c	2026-06-15 12:21:39.368014389 +0900
@@ -5959,8 +5959,17 @@ int amdgpu_device_reinit_after_reset(str
 					amdgpu_ttm_set_buffer_funcs_status(tmp_adev, true);
 
 				r = amdgpu_device_ip_resume_phase3(tmp_adev);
-				if (r)
-					goto out;
+				if (r) {
+					/* DCE (display) resume failure after GPU reset is
+					 * non-fatal on older hardware (e.g. CIK/Hawaii) where
+					 * VRAM shadow restore is unavailable.  The display may
+					 * be temporarily scrambled but the GPU rings are up.
+					 */
+					dev_warn(tmp_adev->dev,
+						 "ip_resume_phase3 (DCE) failed after GPU reset (%d), display may need re-init\n",
+						 r);
+					r = 0;
+				}
 
 				if (vram_lost)
 					amdgpu_device_fill_reset_magic(tmp_adev);
